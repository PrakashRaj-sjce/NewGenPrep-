{
    "manifest_version": 3,
    "name": "AI Interview Bot (Core)",
    "version": "1.0.0",
    "description": "Professional AI interview practice assistant.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://135.235.194.232:8001/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Interview Bot"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost:3000/*",
                "https://aiinterviewbot.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}